{
    "name": "bleeding-deacons/tsml-for-unity",
    "description": "Integration between 12 Step Meeting List (TSML) and Unity plugins for WordPress",
    "type": "wordpress-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "The Bleeding Deacons"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../unity",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.1",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "10up/wp_mock": "^1.0",
        "bleeding-deacons/unity": "@dev",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^9.6|^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "TsmlForUnity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TsmlForUnity\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:coverage": "phpunit --coverage-html ./tests/coverage",
        "cs": "phpcs --standard=WordPress ./src",
        "cs:fix": "phpcbf --standard=WordPress ./src",
        "stan": "@phpstan",
        "check": [
            "@cs",
            "@stan",
            "@test"
        ],
        "build": "php build.php build:production",
        "build:production": "php build.php build:production",
        "build:dev": "php build.php build:dev",
        "build:clean": "php build.php clean",
        "phpstan": "phpstan analyse --memory-limit=1G"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
